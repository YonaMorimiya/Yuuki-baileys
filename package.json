{
  "name": "@yuuki/baileys",
  "type": "module",
  "version": "1.0.0",
  "description": "Yuuki Baileys support lid mapping/group session",
  "keywords": [
    "whatsapp",
    "automation",
    "baileys",
    "lizeneko",
    "Yuuki",
    "whatsapp-api",
    "multi-device",
    "lid-mapping",
    "jid-resolution"
  ],
  "homepage": "https://github.com/YonaMorimiya/Yuuki-baileys",
  "repository": {
    "url": "https://github.com/YonaMorimiya/Yuuki-baileys.git"
  },
  "license": "MIT",
  "author": "Yuuki",
  "main": "./index.cjs",
  "module": "./lib/index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/index.d.ts",
        "default": "./lib/index.js"
      },
      "require": {
        "types": "./index.d.ts",
        "default": "./index.cjs"
      },
      "default": "./lib/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./index.d.ts"
      ]
    }
  },
  "files": [
    "lib/**/*",
    "WAProto/**/*",
    "engine-requirements.js",
    "index.cjs",
    "index.d.ts"
  ],
  "scripts": {
    "lint": "eslint lib --ext .js,.ts",
    "lint:fix": "eslint lib --fix --ext .js,.ts"
  },
  "dependencies": {
    "@cacheable/node-cache": "^1.4.0",
    "@hapi/boom": "^9.1.3",
    "async-mutex": "^0.5.0",
    "audio-decode": "^3.0.0",
    "axios": "^1.13.6",
    "cache-manager": "^5.7.6",
    "chalk": "^5.3.0",
    "cheerio": "^1.2.0",
    "fflate": "^0.8.2",
    "gradient-string": "^3.0.0",
    "libsignal": "git+https://github.com/whiskeysockets/libsignal-node",
    "lru-cache": "^11.1.0",
    "music-metadata": "^11.7.0",
    "p-queue": "^9.0.0",
    "pino": "^9.6",
    "protobufjs": "^7.2.4",
    "whatsapp-rust-bridge": "0.5.2",
    "ws": "^8.13.0"
  },
  "peerDependencies": {
    "jimp": "^1.6.0",
    "link-preview-js": "^3.0.0",
    "sharp": "*"
  },
  "peerDependenciesMeta": {
    "jimp": {
      "optional": true
    },
    "link-preview-js": {
      "optional": true
    }
  },
  "packageManager": "yarn@4.9.2",
  "engines": {
    "node": ">=20.0.0"
  }
}
